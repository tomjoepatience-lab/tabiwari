# ローカル開発用。コピーして .env を作る。
# 例: postgres://ユーザー:パスワード@localhost:5432/tabiwari
DATABASE_URL=postgres://postgres:postgres@localhost:5432/tabiwari
NODE_ENV=development
PORT=3000
# レシートOCR用（唯一のプロバイダ・未設定なら500）。https://aistudio.google.com/apikey で無料発行。1ユーザー1日5回まで。
GEMINI_API_KEY=
# 現在未使用（レシートOCRのClaudeフォールバックは撤去済み）。
ANTHROPIC_API_KEY=sk-ant-...
# 地図（Google Maps JavaScript API）のキー。未設定/無効時は OSM(Leaflet) に自動フォールバック。
# ※ GCP で「Maps JavaScript API」を有効化し、公開ドメインを HTTP リファラ制限に追加すること。
GOOGLE_MAPS_API_KEY=AIzaSy...
