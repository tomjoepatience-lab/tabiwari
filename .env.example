# ローカル開発用。コピーして .env を作る。
# 例: postgres://ユーザー:パスワード@localhost:5432/tabiwari
DATABASE_URL=postgres://postgres:postgres@localhost:5432/tabiwari
NODE_ENV=development
PORT=3000
# レシートOCRの優先プロバイダ。無料ユーザーは1日2回・週5回、マネコプラスは無制限。
GEMINI_API_KEY=
# Geminiが一時的に使えない場合のOCRフォールバック。
ANTHROPIC_API_KEY=sk-ant-...
# 地図（Google Maps JavaScript API）のキー。未設定/無効時は OSM(Leaflet) に自動フォールバック。
# ※ GCP で「Maps JavaScript API」を有効化し、公開ドメインを HTTP リファラ制限に追加すること。
GOOGLE_MAPS_API_KEY=AIzaSy...
# 招待URLとiOS Universal Links
PUBLIC_APP_URL=https://tabiwari-mu.vercel.app
APPLE_TEAM_ID=
# Expo/EAS側に設定するiOS Maps SDKキー（bundle id com.tomjo.maneko に制限）
GOOGLE_MAPS_IOS_API_KEY=
# メール認証・パスワード再設定・サポート通知（Resend）
RESEND_API_KEY=
# Resendで認証済みのドメインから送る。例: マネコ <no-reply@example.com>
AUTH_EMAIL_FROM=
# サポートフォームの通知先（フォーム自体はDBにも保存される）
SUPPORT_EMAIL=
# RevenueCat IAP。公開iOSキーはExpo/EAS、Secret API KeyはVercelだけに設定する。
EXPO_PUBLIC_REVENUECAT_IOS_API_KEY=
REVENUECAT_SECRET_API_KEY=
